{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/login.php" },
    { "source": "/:path*.php", "destination": "/api/:path*.php" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/uploads/:path*", "destination": "/uploads/:path*" }
  ]
}
