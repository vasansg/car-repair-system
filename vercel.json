{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/", "dest": "/api/login.php" },
    { "src": "/([^/]+)\\.php", "dest": "/api/$1.php" },
    { "src": "/(.*)", "dest": "/api/$1" }
  ]
}
