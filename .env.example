# Copy this file to .env and fill in your values
# Railway provides MYSQL_PUBLIC_URL automatically — use that for Vercel

# Option A: single connection string (from Railway Variables tab)
MYSQL_PUBLIC_URL=mysql://root:password@host.proxy.rlwy.net:PORT/railway

# Option B: individual variables (local dev with XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=car_repair_db
DB_USER=root
DB_PASS=

# App
SITE_URL=https://your-vercel-app.vercel.app/

# PHPMailer SMTP (Gmail App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_NAME=CS Kumaresan Motor
